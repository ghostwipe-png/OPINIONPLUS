# Copy this file to .env.local and fill in real values.
# The app runs in full dev/demo mode with none of these set.

# --- Google OAuth ---
# Create an OAuth 2.0 Client ID (Web application) at
# https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000 and your production domain to
# "Authorized JavaScript origins".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Cloudinary (image/video upload) ---
# https://cloudinary.com -> Dashboard for the cloud name.
# Create an UNSIGNED upload preset: Settings -> Upload -> Upload presets.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Backend API (Cloudflare Worker) ---
# The deployed Worker URL, e.g. https://opinionplus-api.yourname.workers.dev
NEXT_PUBLIC_API_BASE=https:
