",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L5\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[\"__PAGE__\",[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"max-w-2xl mx-auto px-5 py-16\",\"children\":[[\"$\",\"p\",null,{\"className\":\"wire-tag mb-3\",\"children\":\"About\"}],[\"$\",\"h1\",null,{\"className\":\"editorial-h text-4xl font-bold mb-8\",\"children\":\"Every voice deserves a masthead.\"}],[\"$\",\"div\",null,{\"className\":\"prose-story text-ink-700 text-[1.05rem]\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Most platforms ask you to shrink your story to fit a feed. OpinionPlus starts from the opposite instinct: your name goes at the top, your logo sits beside it, and the page belongs to you before it belongs to an algorithm.\"}],[\"$\",\"p\",null,{\"children\":\"We built OpinionPlus for the journalist without a masthead, the filmmaker without a distributor, and the person who simply has something true to say and nowhere that feels like theirs to say it. A story here isn't a post lost in a scroll — it's a publication with your byline, your archive, and readers who chose to follow you specifically.\"}],[\"$\",\"p\",null,{\"children\":\"That's the whole idea, really. Give people the tools a real publisher would have — logo, profile, engagement, an audience — and get out of the way. The stories are yours. We just built the newsroom.\"}],[\"$\",\"p\",null,{\"children\":\"OpinionPlus is moderated, not policed. Admins exist to handle abuse and false reports, not to referee opinions. If your story is true and it's yours, it belongs here.\"}]]}]]}],null,[\"$\",\"$L7\",null,{\"children\":[\"$L8\",[\"$\",\"$L9\",null,{\"promise\":\"$@a\"}]]}]]}],{},null,false]},null,false]},null,false],[\"$